# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where waitlist + Card Mania notifications get sent
NOTIFY_EMAIL=hello@curator-os.com

# Verified sender on Resend (must be on a verified domain)
FROM_EMAIL=Curator OS <waitlist@curator-os.com>

# Supabase — for Card Mania feedback storage (and future Curator OS features)
# Get these from supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...  # SENSITIVE — server-only, never expose to browser
